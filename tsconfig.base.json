{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "baseUrl": ".",

    "paths": {
      "@/lib/*": ["web/src/lib/*"],
      "@/components/*": ["web/src/components/*"],
      "@/app/*": ["web/src/app/*"],
      "@/registry/*": ["registry/*"],
      "@tools/*": ["registry/*"],
      "@/*": ["web/src/*"]
    }
  }
}
